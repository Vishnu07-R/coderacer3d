// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  level        Int      @default(1)
  score        Int      @default(0)
  coins        Int      @default(0)
  rewardPoints Int      @default(0)
  equippedCar  String   @default("standard") // ID of the equipped car skin
  ownedCars    String   @default("[\"standard\"]") // JSON array of owned car IDs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LibraryResource {
  id          String   @id @default(uuid())
  title       String
  category    String
  language    String
  difficulty  String
  icon        String
  snippet     String
  content     String   @default("")
  createdAt   DateTime @default(now())
}
