# Backend Server Configuration
# Copy this file to .env and fill in the values

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development

# Database (Prisma)
# For local PostgreSQL: postgresql://user:password@localhost:5432/coderacer3d
# For SQLite: file:./dev.db (relative path for SQLite file)
DATABASE_URL=file:./dev.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Deployment - Update when deploying to production
# BACKEND_PUBLIC_URL=https://your-backend-url.railway.app
# FRONTEND_URL=https://your-frontend-url.vercel.app
